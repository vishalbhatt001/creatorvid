# Root environment file consumed by docker-compose.
# Copy to .env (`cp .env.example .env`) and fill in the secrets you have.
# Per-app .env.example files also exist for running services outside Docker.

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=video_arena

# ---- Object store (MinIO locally, S3-compatible in prod) ----
# The MinIO client is S3-compatible, so the SAME env vars point at either local
# MinIO or a hosted store like DigitalOcean Spaces — only the values change.
#
# Local MinIO (docker-compose) defaults:
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-arena
#
# Production (DigitalOcean Spaces) — set instead:
#   MINIO_ENDPOINT=blr1.digitaloceanspaces.com
#   MINIO_FRONTEND_ENDPOINT=blr1.digitaloceanspaces.com
#   MINIO_PORT=443
#   MINIO_USE_SSL=true
#   MINIO_ACCESS_KEY=<spaces-access-key>
#   MINIO_SECRET_KEY=<spaces-secret-key>
#   MINIO_BUCKET=<your-space-name>
# Public object URLs are then served path-style:
#   https://<MINIO_FRONTEND_ENDPOINT>/<MINIO_BUCKET>/<key>

# ---- URLs ----
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# ---- Auth (better-auth) ----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-production-please-32chars
# Google OAuth (provided later). Authorized redirect URI:
#   http://localhost:4000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated emails granted the "admin" role (can create video templates).
ADMIN_EMAILS=
# Comma-separated superadmin emails: admins who can see and manage EVERY admin's
# templates (not just their own).
SUPERADMIN_EMAILS=

# ---- OpenRouter (provided later) ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Image model used to AI-generate a template's cover thumbnail (from block prompts) on export.
OPENROUTER_THUMBNAIL_MODEL=google/gemini-3.1-flash-image
# Fallback image models (comma-separated) tried in order if the primary fails.
OPENROUTER_THUMBNAIL_FALLBACK_MODELS=bytedance-seed/seedream-4.5,black-forest-labs/flux.2-klein-4b
MINIO_FRONTEND_ENDPOINT=localhost

# ---- Face-swap provider ----
# "facefusion" = classic pixel-level swap; "flux" = diffusion identity edit via an
# OpenRouter image model (accepts a per-block swap context prompt).
SWAP_PROVIDER=facefusion
OPENROUTER_SWAP_MODEL=black-forest-labs/flux.2-klein-4b

# ---- FaceFusion (self-hosted face-swap service) ----
# Reached by the backend container; started with the "facefusion" compose profile.
FACEFUSION_URL=http://facefusion:7865

# Max template blocks generated concurrently per render. Each block hits OpenRouter
# and the CPU-bound FaceFusion service, so a high value floods them and they time
# out on large templates. Keep it low (1 to fully serialize).
RENDER_BLOCK_CONCURRENCY=3

# How many times to attempt a block's video generation before giving up. The
# provider sometimes returns a transient/content-filtered empty result that
# succeeds on retry. Total attempts = this value.
RENDER_VIDEO_MAX_ATTEMPTS=3

# ---- Razorpay (credit purchases) ----
# https://dashboard.razorpay.com/app/keys  (billing is disabled until these are set)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Credit pricing (fixed credits per generation) ----
# Tuned for ~30% margin over typical OpenRouter cost; raise for pricier models.
CREDITS_PER_IMAGE=6
CREDITS_PER_VIDEO=60
CREDITS_PER_TEMPLATE_RENDER=1000
USD_INR_RATE=86