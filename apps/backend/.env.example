# ---- Server ----
NODE_ENV=development
PORT=4000
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# ---- Database (Prisma / Postgres) ----
# Use host "localhost" for local dev, "postgres" when running inside docker-compose.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_arena?schema=public

# ---- Auth (better-auth) ----
# Generate a strong random secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
# Google OAuth credentials (provided later). Authorized redirect URI:
#   http://localhost:4000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated emails granted the "admin" role (can create video templates).
# Matching users are promoted to admin automatically on their next request.
ADMIN_EMAILS=
# Comma-separated superadmin emails: admins who can additionally see and manage
# EVERY admin's templates (not just their own).
SUPERADMIN_EMAILS=

# ---- OpenRouter (video + image model routing) ----
# https://openrouter.ai/keys  (provided later)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Image model used to AI-generate a template's cover thumbnail (from block prompts) on export.
OPENROUTER_THUMBNAIL_MODEL=google/gemini-3.1-flash-image
# Fallback image models (comma-separated) tried in order if the primary fails.
OPENROUTER_THUMBNAIL_FALLBACK_MODELS=bytedance-seed/seedream-4.5,black-forest-labs/flux.2-klein-4b

# ---- Face-swap provider ----
# "facefusion" = classic pixel-level swap (precise, per-person targeting, no prompt).
# "flux" = diffusion identity edit via an OpenRouter image model (higher quality,
# accepts a per-block swap context prompt, regenerates the frame).
SWAP_PROVIDER=facefusion
# Image model used when SWAP_PROVIDER=flux (must accept reference images).
OPENROUTER_SWAP_MODEL=black-forest-labs/flux.2-klein-4b

# ---- FaceFusion (self-hosted face-swap service) ----
# Use "localhost" for host-based dev, "facefusion" when running inside docker-compose.
# Start it with: docker compose --profile facefusion up -d --build facefusion
FACEFUSION_URL=http://localhost:7865

# Max template blocks generated concurrently per render. Each block hits OpenRouter
# and the CPU-bound FaceFusion service, so a high value floods them and they time
# out on large templates. Keep it low (1 to fully serialize).
RENDER_BLOCK_CONCURRENCY=3

# How many times to attempt a block's video generation before giving up. The
# provider sometimes returns a transient/content-filtered empty result that
# succeeds on retry. Total attempts = this value.
RENDER_VIDEO_MAX_ATTEMPTS=3

# ---- Razorpay (credit purchases) ----
# Get keys from https://dashboard.razorpay.com/app/keys (use test keys in dev).
# Without these, the billing endpoints return 503 and the rest of the app works.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: webhook signing secret (Razorpay dashboard → Webhooks). If set, the
# /api/credits/webhook endpoint grants credits on payment.captured as a backstop.
RAZORPAY_WEBHOOK_SECRET=

# ---- Credit pricing (fixed price per action) ----
# Each generation costs a flat number of credits regardless of which model is
# chosen. Defaults keep ~30% margin over typical OpenRouter cost even at the
# best-value (Studio) pack. If you enable pricier models, raise these: choose
# credits >= providerCostUSD * USD_INR_RATE * 1.72.
CREDITS_PER_IMAGE=6
CREDITS_PER_VIDEO=60
CREDITS_PER_TEMPLATE_RENDER=1000
# USD->INR rate, used only for the pricing helper's margin estimates.
USD_INR_RATE=86

# ---- MinIO (object store) ----
# Use host "localhost" for local dev, "minio" when running inside docker-compose.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-arena
